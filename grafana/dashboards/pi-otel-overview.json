    {"type":"stat","title":"Prompts","gridPos":{"h":4,"w":4,"x":4,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"expr":"sum(increase(pi_prompt_count_total[$__range]))","refId":"A"}]},
