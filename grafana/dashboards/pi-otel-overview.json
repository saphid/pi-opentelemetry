    {"type":"stat","title":"Tool calls","gridPos":{"h":4,"w":4,"x":12,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"expr":"sum(increase(pi_tool_call_count_total[$__range]))","refId":"A"}]},
    {"type":"stat","title":"Tool errors","gridPos":{"h":4,"w":4,"x":16,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"expr":"sum(increase(pi_tool_result_count_total{success=\"false\"}[$__range]))","refId":"A"}]},
