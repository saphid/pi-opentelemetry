    {"type":"timeseries","title":"Resource usage by package","gridPos":{"h":8,"w":12,"x":12,"y":4},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"expr":"sum by (source_package) (rate(pi_resource_usage_count_total[$__rate_interval]))","legendFormat":"{{source_package}}","refId":"A"}]},
    {"type":"barchart","title":"Resource usage in range","gridPos":{"h":8,"w":12,"x":0,"y":12},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"expr":"topk(20, sum by (source_package, kind, name, event) (increase(pi_resource_usage_count_total[$__range])))","legendFormat":"{{source_package}} / {{kind}} / {{name}} / {{event}}","refId":"A","format":"time_series"}]},
    {"type":"timeseries","title":"Tokens by type","gridPos":{"h":8,"w":12,"x":12,"y":12},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"expr":"sum by (type) (rate(pi_token_usage_total[$__rate_interval]))","legendFormat":"{{type}}","refId":"A"}]},
    {"type":"timeseries","title":"Tool duration p95","gridPos":{"h":8,"w":12,"x":0,"y":20},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"expr":"histogram_quantile(0.95, sum by (le, tool_name) (rate(pi_tool_duration_bucket[$__rate_interval])))","legendFormat":"{{tool_name}}","refId":"A"}]},
    {"type":"timeseries","title":"Prompt length p95","gridPos":{"h":8,"w":12,"x":12,"y":20},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"expr":"histogram_quantile(0.95, sum by (le) (rate(pi_prompt_length_bucket[$__rate_interval])))","legendFormat":"p95 chars","refId":"A"}]}
